# =============================================================================
# Production Environment Configuration - Chatbot Platform API
# =============================================================================
# This file contains production-specific settings
# DO NOT commit actual secrets - use a secrets manager
# =============================================================================

# =============================================================================
# Application
# =============================================================================
NODE_ENV=production
PORT=3000
API_VERSION=v1
APP_NAME=Chatbot Platform
APP_URL=https://api.chatbot-platform.com

# =============================================================================
# Database - PostgreSQL (Production)
# =============================================================================
# Use connection string from secrets manager
DATABASE_URL=${DATABASE_URL_SECRET}
POSTGRES_HOST=postgres.chatbot-platform.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=chatbot
POSTGRES_USER=${POSTGRES_USER_SECRET}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD_SECRET}

# Connection pool (higher for production)
POSTGRES_POOL_MIN=5
POSTGRES_POOL_MAX=20
POSTGRES_CONNECTION_TIMEOUT=30000
POSTGRES_IDLE_TIMEOUT=10000

# SSL for production
POSTGRES_SSL=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# =============================================================================
# Cache - Redis (Production with Sentinel/Cluster)
# =============================================================================
REDIS_URL=${REDIS_URL_SECRET}
REDIS_HOST=redis.chatbot-platform.svc.cluster.local
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD_SECRET}
REDIS_DB=0

# Redis Sentinel (if using HA)
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_MASTER_NAME=

# Redis Cluster (if using cluster mode)
REDIS_CLUSTER_NODES=

# =============================================================================
# AWS S3 Configuration (Production)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID_SECRET}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY_SECRET}
AWS_S3_BUCKET=chatbot-uploads-prod
S3_QUARANTINE_BUCKET=chatbot-quarantine-prod

# CloudFront CDN (Production)
CLOUDFRONT_DOMAIN=cdn.chatbot-platform.com
CLOUDFRONT_KEY_PAIR_ID=${CLOUDFRONT_KEY_PAIR_ID_SECRET}
CLOUDFRONT_PRIVATE_KEY=${CLOUDFRONT_PRIVATE_KEY_SECRET}

# S3 Encryption
S3_SERVER_SIDE_ENCRYPTION=AES256
S3_BUCKET_KEY_ENABLED=true

# =============================================================================
# ClamAV Virus Scanner (Production)
# =============================================================================
CLAMAV_HOST=clamav.chatbot-platform.svc.cluster.local
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=120000

# =============================================================================
# n8n Workflow Automation (Production)
# =============================================================================
N8N_WEBHOOK_URL=https://n8n.chatbot-platform.com
N8N_API_KEY=${N8N_API_KEY_SECRET}

# =============================================================================
# Stripe / Billing (Production)
# =============================================================================
# Required in production. Boot fails fast if any of the four are missing.
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY_SECRET}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET_SECRET}
# Live-mode Price IDs from the Stripe dashboard (Essential: €49.99/mo,
# Pro: €99.99/mo, EUR recurring, ex-VAT).
STRIPE_PRICE_ESSENTIAL=${STRIPE_PRICE_ESSENTIAL}
STRIPE_PRICE_PRO=${STRIPE_PRICE_PRO}
# Forward-trial is Stripe-native (subscription_data.trial_period_days: 14
# at Checkout creation). No local trial-expiry job.

# =============================================================================
# Security (Production Hardening)
# =============================================================================

# JWT Configuration (Strong secrets required)
JWT_SECRET=${JWT_SECRET_SECRET}
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=chatbot-platform
JWT_AUDIENCE=chatbot-api

# Encryption Keys (MUST be 32 bytes, base64 encoded, from secrets manager)
ENCRYPTION_KEY=${ENCRYPTION_KEY_SECRET}
FIELD_ENCRYPTION_KEY=${FIELD_ENCRYPTION_KEY_SECRET}
HMAC_SECRET=${HMAC_SECRET_SECRET}

# Password Policy (Stricter for production)
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=5

# Rate Limiting (Stricter for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_AUTH_MAX=5

# CORS (Restrictive for production)
CORS_ORIGIN=https://app.chatbot-platform.com,https://admin.chatbot-platform.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID

# Session (Secure settings)
SESSION_SECRET=${SESSION_SECRET_SECRET}
SESSION_MAX_AGE=3600000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# API Keys
API_KEY_HEADER=X-API-Key
WEBHOOK_SECRET=${WEBHOOK_SECRET_SECRET}

# Content Security Policy
CSP_REPORT_URI=https://api.chatbot-platform.com/api/v1/security/csp-report
CSP_REPORT_ONLY=false

# =============================================================================
# File Upload (Production)
# =============================================================================
UPLOAD_MAX_FILE_SIZE=26214400
UPLOAD_MAX_FILES_PER_REQUEST=5
UPLOAD_CHUNK_SIZE=5242880
UPLOAD_URL_EXPIRES_IN=300
UPLOAD_ENABLE_VIRUS_SCAN=true
UPLOAD_ENABLE_THUMBNAILS=true
UPLOAD_RETENTION_DAYS=30

# =============================================================================
# Thumbnail Generation (Production)
# =============================================================================
THUMBNAIL_QUALITY=80
THUMBNAIL_FORMAT=webp
THUMBNAIL_SIZES=thumb:150x150,small:300x300,medium:600x600,large:1200x1200

# =============================================================================
# Logging (Production)
# =============================================================================
LOG_LEVEL=warn
LOG_DIRECTORY=/app/logs
LOG_MAX_SIZE=100m
LOG_MAX_FILES=30
LOG_FORMAT=json

# External log aggregation
LOG_AGGREGATOR_URL=
LOG_AGGREGATOR_API_KEY=

# Audit log retention (GDPR compliance)
AUDIT_LOG_RETENTION_DAYS=365

# =============================================================================
# Feature Flags (Production)
# =============================================================================
ENABLE_WEBSOCKET=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_CSP=true
ENABLE_XSS_PROTECTION=true
ENABLE_FILE_VALIDATION=true
ENABLE_TENANT_ISOLATION=true
ENABLE_MAINTENANCE_MODE=false

# =============================================================================
# Monitoring (Production)
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
HEALTH_CHECK_PATH=/health

# APM Integration
APM_ENABLED=true
APM_SERVICE_NAME=chatbot-api
APM_SERVER_URL=
APM_SECRET_TOKEN=

# Distributed tracing
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=0.1

# =============================================================================
# Email (Production)
# =============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=${SMTP_PASSWORD_SECRET}
SMTP_FROM=noreply@chatbot-platform.com
SMTP_SECURE=true

# =============================================================================
# External Services (Production)
# =============================================================================
# OpenAI
OPENAI_API_KEY=${OPENAI_API_KEY_SECRET}
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT=30000

# Anthropic (Claude)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY_SECRET}

# Google Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-credentials.json
GOOGLE_PROJECT_ID=chatbot-platform-prod

# =============================================================================
# Backup & Disaster Recovery
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=chatbot-backups-prod

# =============================================================================
# Performance Tuning
# =============================================================================
# Worker threads
UV_THREADPOOL_SIZE=128

# Node.js
NODE_OPTIONS=--max-old-space-size=4096

# =============================================================================
# Compliance
# =============================================================================
# GDPR
GDPR_DATA_RETENTION_DAYS=2555  # 7 years
GDPR_RIGHT_TO_ERASURE_ENABLED=true
GDPR_DATA_PORTABILITY_ENABLED=true

# SOC 2
SOC2_AUDIT_LOGGING_ENABLED=true
SOC2_ACCESS_CONTROL_ENABLED=true
SOC2_ENCRYPTION_AT_REST=true
SOC2_ENCRYPTION_IN_TRANSIT=true
