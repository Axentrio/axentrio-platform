# === Required (auto-provided by Railway) ===
# DATABASE_URL=postgresql://...  (from Railway PostgreSQL plugin)
# REDIS_URL=redis://...          (from Railway Redis plugin)
# PORT=3000                      (assigned by Railway)

# === Required (set manually) ===
NODE_ENV=production
API_URL=https://your-api.up.railway.app
JWT_SECRET=                      # openssl rand -base64 32
JWT_REFRESH_SECRET=              # openssl rand -base64 32
ENCRYPTION_KEY=                  # openssl rand -base64 32
WIDGET_API_KEY=                  # openssl rand -base64 24
CORS_ORIGIN=https://your-portal.up.railway.app

# === Database (only needed if not using DATABASE_URL) ===
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=chatbot_platform
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=false

# === Redis (only needed if not using REDIS_URL) ===
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# === JWT ===
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# === AWS S3 (required for file uploads) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=

# === Optional S3 settings ===
# S3_ENDPOINT=                   # For S3-compatible services
# S3_FORCE_PATH_STYLE=false
# S3_SIGNED_URL_EXPIRY=900
# CDN_URL=                       # If not set, files served via S3 signed URLs

# === Stripe / Billing (required outside of NODE_ENV=test) ===
# Boot fails fast if any of these four are missing or empty.
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret. For local dev, run:
#   stripe listen --forward-to localhost:4081/api/v1/webhooks/billing/stripe
# and paste the printed `whsec_...` here.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring Price IDs from https://dashboard.stripe.com/test/products
# Pro = $49/mo, Premium = $199/mo (USD). One Price per plan.
STRIPE_PRICE_PRO_USD_MONTHLY=price_xxx
STRIPE_PRICE_PREMIUM_USD_MONTHLY=price_xxx
# Reverse-trial length in days. Every new tenant gets `trialing-pro` for
# this many days, then the trial-expiry job (Bull) drops them to free.
# BILLING_TRIAL_DAYS=7

# === Optional ===
# N8N_WEBHOOK_URL=               # If not set, message forwarding disabled
# N8N_DEFAULT_WEBHOOK_URL=http://localhost:5678/webhook/chatbot-platform
# RAG_INTERNAL_SECRET=change-me-in-production
# N8N_INBOUND_SECRET=change-me-in-production
# CLAMAV_HOST=                   # If not set, virus scanning skipped
# CLAMAV_PORT=3310
# LOG_LEVEL=info
# LOG_FORMAT=combined
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# LLM_DAILY_LIMIT_PER_TENANT=5000   # env fallback if entitlements lookup fails
