          }
        ]
      ]
    },
    "Vision Analysis": {
      "main": [
        [
          {
            "node": "Image Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Image Response": {
      "main": [
        [
          {
            "node": "Send Response",
            "type": "main",
            "index": 0
          }
        ]
      ]
