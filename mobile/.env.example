# Copy to mobile/.env and fill in. Only EXPO_PUBLIC_* vars reach the app bundle.

# Local API (Express). On a physical device use your machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=http://localhost:4081
EXPO_PUBLIC_WS_URL=http://localhost:4081

# Clerk publishable key. A development instance (pk_test_...) needs no Apple/Play
# setup and is enough to verify auth locally.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
