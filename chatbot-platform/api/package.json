{
  "name": "chatbot-platform-api",
  "version": "1.0.0",
  "description": "Core API Server with WebSocket Gateway for Chatbot Platform",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "npm run typeorm migration:run -- -d src/database/data-source.ts",
    "migration:generate": "npm run typeorm migration:generate -- -d src/database/data-source.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "chatbot",
    "websocket",
    "socket.io",
    "redis",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "@clerk/backend": "^3.2.2",
    "@clerk/express": "^2.0.6",
    "@sentry/node": "^10.46.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dompurify": "^3.3.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.23",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pg-connection-string": "^2.12.0",
    "pgvector": "^0.2.1",
    "rate-limit-redis": "^4.3.1",
    "rate-limiter-flexible": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "svix": "^1.89.0",
    "tsconfig-paths": "^4.2.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.1",
    "@types/json-schema": "^7.0.15",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^9.0.7",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
