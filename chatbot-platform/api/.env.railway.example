# Railway Production Environment Variables
# Copy this to .env.railway and fill in your values
# Or set these directly in Railway dashboard

# Server Configuration
NODE_ENV=production
PORT=3000
API_URL=https://your-api.railway.app

# Database (PostgreSQL) - Auto-provided by Railway
# DATABASE_URL will be auto-populated by Railway PostgreSQL plugin

# Redis - Auto-provided by Railway
# REDIS_URL will be auto-populated by Railway Redis plugin

# JWT Configuration (Generate strong secrets!)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long

# Widget API Key (Generate a secure random string)
WIDGET_API_KEY=your-secure-widget-api-key

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# AWS S3 Configuration (Required)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=your-production-bucket

# Optional: CloudFront CDN
CDN_URL=https://your-cloudfront-domain.cloudfront.net

# File Upload Settings
MAX_FILE_SIZE=26214400
S3_SIGNED_URL_EXPIRY=900

# n8n Integration
N8N_DEFAULT_WEBHOOK_URL=http://localhost:5678/webhook/chatbot-platform
RAG_INTERNAL_SECRET=change-me-in-production
N8N_INBOUND_SECRET=change-me-in-production
N8N_WEBHOOK_TIMEOUT=5000
N8N_RETRY_ATTEMPTS=3
N8N_RETRY_DELAY=1000
N8N_CIRCUIT_BREAKER_THRESHOLD=5
N8N_CIRCUIT_BREAKER_TIMEOUT=60000

# ClamAV Virus Scanning (optional - use managed service or deploy separately)
# CLAMAV_HOST=your-clamav-service.railway.app
# CLAMAV_PORT=3310

# Encryption (Generate a secure 32-character key!)
ENCRYPTION_KEY=your-32-character-encryption-key

# OpenAI (required for RAG + LLM chat)
OPENAI_API_KEY=sk-your-openai-api-key

# CORS Configuration (Add your production portal URL)
CORS_ORIGIN=https://your-portal.railway.app,https://your-custom-domain.com

# Portal URL
PORTAL_URL=https://your-portal.railway.app
